# Rust
/target/
**/*.rs.bk
*.pdb

# Python (eval harness)
__pycache__/
*.py[cod]
.venv/
eval/.venv/

# Eval artifacts & datasets (large / reproducible — never committed)
/data/
/datasets/
eval/results/
eval/_run/
*.tum
*.bag
*.mcap
# Small committed test fixtures are the exception to the data-is-never-committed rule.
!eval/**/fixtures/**/*.tum
!crates/**/tests/fixtures/**/*.bag

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
