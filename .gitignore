# Rust
/target/
**/*.rs.bk
*.pdb

# Python (eval harness)
__pycache__/
*.py[cod]
.venv/
eval/.venv/

# TensorRT engines are GPU- and TRT-version-specific — rebuild per target, never commit
# (the portable .onnx exports in onnx/ ARE committed; see onnx/README.md).
*.engine

# Eval artifacts & datasets (large / reproducible — never committed)
/data/
/datasets/
eval/results/
eval/_run/
*.tum
*.bag
*.mcap

docs/*.pdf

# Small committed test fixtures are the exception to the data-is-never-committed rule.
!eval/**/fixtures/**/*.tum
!crates/**/tests/fixtures/**/*.bag

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
